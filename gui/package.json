{
  "name": "yuque-dl-gui",
  "version": "1.0.0",
  "main": "main.js",
  "description": "语雀知识库下载器GUI版本",
  "author": "hubu008",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.example.yuquedl",
    "productName": "Yuque Downloader",
    "directories": {
      "output": "dist"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "unicode": true,
      "language": "2052"
    }
  }
}
